{
  "name": "night-shift-viewer-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "API over night-shift .night-shift/ artifacts and git diffs. Read-only by default; launching is opt-in via NSV_ALLOW_LAUNCH / NSV_ALLOW_REAL.",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "dev:launch": "NSV_ALLOW_LAUNCH=1 caffeinate -i node src/server.js",
    "dev:real": "NSV_ALLOW_LAUNCH=1 NSV_ALLOW_REAL=1 caffeinate -i node src/server.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "chokidar": "^4.0.3",
    "hono": "^4.12.0",
    "parse-diff": "^0.11.1",
    "simple-git": "^3.27.0"
  }
}
